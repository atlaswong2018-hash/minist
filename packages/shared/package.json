{
  "name": "@minist/shared",
  "version": "0.1.0",
  "private": true,
  "description": "minist 跨端共享契约:路由常量、加密协议、配置与同步类型、API 信封。",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./routes": {
      "types": "./src/routes.ts",
      "default": "./src/routes.ts"
    },
    "./crypto": {
      "types": "./src/crypto.ts",
      "default": "./src/crypto.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "files": [
    "src",
    "dist"
  ],
  "devDependencies": {
    "typescript": "~5.6.3"
  }
}
