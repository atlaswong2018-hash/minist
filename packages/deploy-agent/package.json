{
  "name": "@minist/deploy-agent",
  "version": "0.1.0",
  "private": true,
  "description": "minist AI 部署助手:系统 prompt + 避坑知识库 + 关键词检索 + OpenAI 兼容消息组装。",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./knowledge": {
      "types": "./src/knowledge.ts",
      "default": "./src/knowledge.ts"
    },
