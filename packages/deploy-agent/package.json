      "types": "./src/prompts.ts",
      "default": "./src/prompts.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "files": [
    "src",
    "dist"
  ],
  "dependencies": {
    "@minist/shared": "*"
  },
  "devDependencies": {
    "typescript": "~5.6.3"
  }
}
