{
  "name": "@minist/core",
  "version": "0.1.0",
  "private": true,
  "description": "minist 纯逻辑核心库:人物卡(PNG/JSON,V1/V2/V3)、世界书激活、Prompt 构建。零 Node 专有 API,浏览器可用。",
  "license": "AGPL-3.0-only",
  "author": "minist contributors",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./character-card": {
      "types": "./src/character-card/index.ts",
      "default": "./src/character-card/index.ts"
    },
    "./worldinfo": {
      "types": "./src/worldinfo/index.ts",
      "default": "./src/worldinfo/index.ts"
    },
    "./prompt": {
      "types": "./src/prompt/index.ts",
      "default": "./src/prompt/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "files": [
    "src",
    "dist"
  ],
  "dependencies": {
    "@minist/shared": "*"
  },
  "devDependencies": {
    "typescript": "~5.6.3"
  }
}
